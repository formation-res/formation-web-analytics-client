{
  "name": "@tryformation/formation-web-analytics-client",
  "version": "0.1.0",
  "description": "Light weight browser analytics client intended to be used with the formation-web-analytics server.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tryformation/formation-web-analytics-client.git"
  },
  "homepage": "https://github.com/tryformation/formation-web-analytics-client#readme",
  "bugs": {
    "url": "https://github.com/tryformation/formation-web-analytics-client/issues"
  },
  "keywords": [
    "analytics",
    "browser",
    "formation",
    "tracking",
    "web-analytics"
  ],
  "engines": {
    "node": ">=20.19.0"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/analytics.js",
  "module": "./dist/analytics.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/analytics.js",
      "default": "./dist/analytics.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist && vite build && vite build --config vite.iife.config.ts && tsc -p tsconfig.build.json",
    "lint": "eslint .",
    "test": "vitest run",
    "audit": "npm audit",
    "verify": "npm run lint && npm test && npm run build && npm run audit",
    "prepublishOnly": "npm run verify"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "jsdom": "^29.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  }
}
